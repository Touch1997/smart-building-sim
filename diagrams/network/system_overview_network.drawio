        <mxCell id="kKMMps9GIU_p9-2Uxnd1-22" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=16;container=0;" value="Modbus TCP (Port 502)" vertex="1">
