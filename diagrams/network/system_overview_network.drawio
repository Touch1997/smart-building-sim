        </mxCell>
        <mxCell id="kKMMps9GIU_p9-2Uxnd1-23" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;autosizeText=1;fontSize=11;align=left;" value="&lt;div&gt;&lt;div&gt;&lt;span&gt;This diagram shows the integrated building network for BACnet/IP HVAC systems, Modbus electrical meters, and outdoor environmental sensors.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;Node-RED acts as the edge gateway for protocol integration, data processing, and MQTT publishing.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;Note:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;- BACnet device instances must be unique within the BACnet network.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;- Modbus slave IDs must be unique per RS-485 segment.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;- Duplicate Modbus slave IDs are allowed across different gateways.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;- Outdoor sensors are integrated via RTU-TCP gateways.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;- All IP-based devices are connected within the same subnet.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;- All devices are within subnet: 192.168.10.0/24&lt;span&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="340" x="670" y="498.6700000000001" as="geometry" />
        </mxCell>
