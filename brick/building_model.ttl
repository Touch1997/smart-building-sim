# --- Chiller 1 Points ---------------------------------------------------------
bldg:ch1_evap_lwt a brick:Water_Temperature_Sensor ;
    rdfs:label "CH-1 evaporator leaving water temperature" ;
    brick:isPointOf bldg:chiller_1 .

bldg:ch1_evap_ewt a brick:Water_Temperature_Sensor ;
    rdfs:label "CH-1 evaporator entering water temperature" ;
    brick:isPointOf bldg:chiller_1 .

