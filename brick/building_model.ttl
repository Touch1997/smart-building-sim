@prefix brick: <https://brickschema.org/schema/Brick#> .
@prefix bldg:  <urn:altotech:iot-assessment/> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

# Brick model for the AltoTech IoT Engineer Assessment
# Note: Brick 1.4 deprecates some location classes in favor of REC,
# but this model keeps brick:Building / brick:Floor for simplicity and to match the assessment wording.

###############################################################################
# BUILDING, FLOORS, ZONES
###############################################################################


# -----------------------------------------------------------------------------
# SECTION A: BUILDING OVERVIEW
# เริ่มจากโครงสร้างบนสุดของอาคาร: Building -> Floor -> HVAC Zone
# -----------------------------------------------------------------------------
bldg:building a brick:Building ;
    rdfs:label "4F Commercial Office Building" ;
    brick:hasPart bldg:floor_1, bldg:floor_2, bldg:floor_3, bldg:floor_4 .


# ============================= FLOOR 1 =============================
# ชั้น 1 และ 4 HVAC zones ของชั้น 1
# -------------------------------------------------------------------
bldg:floor_1 a brick:Floor ;
    rdfs:label "Floor 1" ;
    brick:isPartOf bldg:building ;
    brick:hasPart bldg:zone_f1_z1, bldg:zone_f1_z2, bldg:zone_f1_z3, bldg:zone_f1_z4 .

bldg:zone_f1_z1 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F1-Z1" ;
    brick:isPartOf bldg:floor_1 .

bldg:zone_f1_z2 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F1-Z2" ;
    brick:isPartOf bldg:floor_1 .

bldg:zone_f1_z3 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F1-Z3" ;
    brick:isPartOf bldg:floor_1 .

bldg:zone_f1_z4 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F1-Z4" ;
    brick:isPartOf bldg:floor_1 .


# ============================= FLOOR 2 =============================
# ชั้น 2 และ 4 HVAC zones ของชั้น 2
# -------------------------------------------------------------------
bldg:floor_2 a brick:Floor ;
    rdfs:label "Floor 2" ;
    brick:isPartOf bldg:building ;
    brick:hasPart bldg:zone_f2_z1, bldg:zone_f2_z2, bldg:zone_f2_z3, bldg:zone_f2_z4 .

bldg:zone_f2_z1 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F2-Z1" ;
    brick:isPartOf bldg:floor_2 .

bldg:zone_f2_z2 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F2-Z2" ;
    brick:isPartOf bldg:floor_2 .

bldg:zone_f2_z3 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F2-Z3" ;
    brick:isPartOf bldg:floor_2 .

bldg:zone_f2_z4 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F2-Z4" ;
    brick:isPartOf bldg:floor_2 .


# ============================= FLOOR 3 =============================
# ชั้น 3 และ 4 HVAC zones ของชั้น 3
# -------------------------------------------------------------------
bldg:floor_3 a brick:Floor ;
    rdfs:label "Floor 3" ;
    brick:isPartOf bldg:building ;
    brick:hasPart bldg:zone_f3_z1, bldg:zone_f3_z2, bldg:zone_f3_z3, bldg:zone_f3_z4 .

bldg:zone_f3_z1 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F3-Z1" ;
    brick:isPartOf bldg:floor_3 .

bldg:zone_f3_z2 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F3-Z2" ;
    brick:isPartOf bldg:floor_3 .

bldg:zone_f3_z3 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F3-Z3" ;
    brick:isPartOf bldg:floor_3 .

bldg:zone_f3_z4 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F3-Z4" ;
    brick:isPartOf bldg:floor_3 .


# ============================= FLOOR 4 =============================
# ชั้น 4 และ 4 HVAC zones ของชั้น 4
# -------------------------------------------------------------------
bldg:floor_4 a brick:Floor ;
    rdfs:label "Floor 4" ;
    brick:isPartOf bldg:building ;
    brick:hasPart bldg:zone_f4_z1, bldg:zone_f4_z2, bldg:zone_f4_z3, bldg:zone_f4_z4 .

bldg:zone_f4_z1 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F4-Z1" ;
    brick:isPartOf bldg:floor_4 .

bldg:zone_f4_z2 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F4-Z2" ;
    brick:isPartOf bldg:floor_4 .

bldg:zone_f4_z3 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F4-Z3" ;
    brick:isPartOf bldg:floor_4 .

bldg:zone_f4_z4 a brick:HVAC_Zone ;
    rdfs:label "HVAC Zone F4-Z4" ;
    brick:isPartOf bldg:floor_4 .


# ============================== ROOF ===============================
# พื้นที่ดาดฟ้า ใช้เป็น location ของ Cooling Tower และ Weather Station
# -------------------------------------------------------------------
bldg:roof a brick:Location ;
    rdfs:label "Roof" ;
    brick:isPartOf bldg:building .

###############################################################################
# HVAC EQUIPMENT
###############################################################################


# -----------------------------------------------------------------------------
# SECTION B: CHILLER PLANT EQUIPMENT
# กลุ่มอุปกรณ์หลักใน Chiller Plant: Chiller / CHWP / CDWP / Cooling Tower
# -----------------------------------------------------------------------------

# --- Chillers ----------------------------------------------------------------
bldg:chiller_1 a brick:Chiller ;
    rdfs:label "Chiller 1" ;
    brick:hasLocation bldg:building ;
    brick:hasPoint bldg:ch1_evap_lwt, bldg:ch1_evap_ewt, bldg:ch1_evap_flow, bldg:ch1_evap_sat_refrig_temp, bldg:ch1_evap_delta_temp, bldg:ch1_evap_approach_temp, bldg:ch1_status_read, bldg:ch1_status_write, bldg:ch1_power, bldg:ch1_alarm, bldg:ch1_percentage_rla, bldg:ch1_efficiency, bldg:ch1_cooling_rate .

bldg:chiller_2 a brick:Chiller ;
    rdfs:label "Chiller 2" ;
    brick:hasLocation bldg:building ;
    brick:hasPoint bldg:ch2_evap_lwt, bldg:ch2_evap_ewt, bldg:ch2_evap_flow, bldg:ch2_evap_sat_refrig_temp, bldg:ch2_evap_delta_temp, bldg:ch2_evap_approach_temp, bldg:ch2_status_read, bldg:ch2_status_write, bldg:ch2_power, bldg:ch2_alarm, bldg:ch2_percentage_rla, bldg:ch2_efficiency, bldg:ch2_cooling_rate .

bldg:chiller_3 a brick:Chiller ;
    rdfs:label "Chiller 3" ;
    brick:hasLocation bldg:building ;
    brick:hasPoint bldg:ch3_evap_lwt, bldg:ch3_evap_ewt, bldg:ch3_evap_flow, bldg:ch3_evap_sat_refrig_temp, bldg:ch3_evap_delta_temp, bldg:ch3_evap_approach_temp, bldg:ch3_status_read, bldg:ch3_status_write, bldg:ch3_power, bldg:ch3_alarm, bldg:ch3_percentage_rla, bldg:ch3_efficiency, bldg:ch3_cooling_rate .


# --- Chilled Water Pumps (CHWP) ----------------------------------------------
bldg:chwp_1 a brick:Pump ;
    rdfs:label "Chilled Water Pump 1" ;
    brick:hasLocation bldg:building ;
    brick:hasPoint bldg:chwp1_status_read, bldg:chwp1_status_write, bldg:chwp1_alarm, bldg:chwp1_frequency_read, bldg:chwp1_frequency_write, bldg:chwp1_power, bldg:chwp1_efficiency .

bldg:chwp_2 a brick:Pump ;
    rdfs:label "Chilled Water Pump 2" ;
    brick:hasLocation bldg:building ;
    brick:hasPoint bldg:chwp2_status_read, bldg:chwp2_status_write, bldg:chwp2_alarm, bldg:chwp2_frequency_read, bldg:chwp2_frequency_write, bldg:chwp2_power, bldg:chwp2_efficiency .

bldg:chwp_3 a brick:Pump ;
    rdfs:label "Chilled Water Pump 3" ;
    brick:hasLocation bldg:building ;
    brick:hasPoint bldg:chwp3_status_read, bldg:chwp3_status_write, bldg:chwp3_alarm, bldg:chwp3_frequency_read, bldg:chwp3_frequency_write, bldg:chwp3_power, bldg:chwp3_efficiency .


# --- Condenser Water Pumps (CDWP) --------------------------------------------
bldg:cdwp_1 a brick:Pump ;
    rdfs:label "Condenser Water Pump 1" ;
    brick:hasLocation bldg:building ;
    brick:hasPoint bldg:cdwp1_status_read, bldg:cdwp1_status_write, bldg:cdwp1_alarm, bldg:cdwp1_frequency_read, bldg:cdwp1_frequency_write, bldg:cdwp1_power, bldg:cdwp1_efficiency .

bldg:cdwp_2 a brick:Pump ;
    rdfs:label "Condenser Water Pump 2" ;
    brick:hasLocation bldg:building ;
    brick:hasPoint bldg:cdwp2_status_read, bldg:cdwp2_status_write, bldg:cdwp2_alarm, bldg:cdwp2_frequency_read, bldg:cdwp2_frequency_write, bldg:cdwp2_power, bldg:cdwp2_efficiency .

bldg:cdwp_3 a brick:Pump ;
    rdfs:label "Condenser Water Pump 3" ;
    brick:hasLocation bldg:building ;
    brick:hasPoint bldg:cdwp3_status_read, bldg:cdwp3_status_write, bldg:cdwp3_alarm, bldg:cdwp3_frequency_read, bldg:cdwp3_frequency_write, bldg:cdwp3_power, bldg:cdwp3_efficiency .


# --- Cooling Towers -----------------------------------------------------------
bldg:ct_1 a brick:Cooling_Tower ;
    rdfs:label "Cooling Tower 1" ;
    brick:hasLocation bldg:roof ;
    brick:hasPoint bldg:ct1_status_read, bldg:ct1_status_write, bldg:ct1_alarm, bldg:ct1_frequency_read, bldg:ct1_frequency_write, bldg:ct1_power, bldg:ct1_efficiency .

bldg:ct_2 a brick:Cooling_Tower ;
    rdfs:label "Cooling Tower 2" ;
    brick:hasLocation bldg:roof ;
    brick:hasPoint bldg:ct2_status_read, bldg:ct2_status_write, bldg:ct2_alarm, bldg:ct2_frequency_read, bldg:ct2_frequency_write, bldg:ct2_power, bldg:ct2_efficiency .

bldg:ct_3 a brick:Cooling_Tower ;
    rdfs:label "Cooling Tower 3" ;
    brick:hasLocation bldg:roof ;
    brick:hasPoint bldg:ct3_status_read, bldg:ct3_status_write, bldg:ct3_alarm, bldg:ct3_frequency_read, bldg:ct3_frequency_write, bldg:ct3_power, bldg:ct3_efficiency .


# -----------------------------------------------------------------------------
# SECTION C: AIR DISTRIBUTION SYSTEM
# AHU 1 ตัวต่อชั้น และ 4 VAV ต่อชั้น
# แต่ละ AHU feeds ไปยัง VAV ของชั้นนั้น
# -----------------------------------------------------------------------------

# --- AHU & Motorized Valve : Floor 1 -----------------------------------------
bldg:ahu_1 a brick:AHU ;
    rdfs:label "AHU Floor 1" ;
    brick:hasLocation bldg:floor_1 ;
    brick:hasPart bldg:mv_ahu_1 ;
    brick:feeds bldg:vav_f1_z1, bldg:vav_f1_z2, bldg:vav_f1_z3, bldg:vav_f1_z4 ;
    brick:hasPoint bldg:ahu1_room_temp, bldg:ahu1_setpoint, bldg:ahu1_status_read, bldg:ahu1_status_write, bldg:ahu1_humidity, bldg:ahu1_alarm, bldg:ahu1_power .

bldg:mv_ahu_1 a brick:Valve ;
    rdfs:label "Motorized Valve AHU 1" ;
    brick:isPartOf bldg:ahu_1 ;
    brick:hasPoint bldg:mv1_status_read, bldg:mv1_status_write, bldg:mv1_alarm .


# --- AHU & Motorized Valve : Floor 2 -----------------------------------------
bldg:ahu_2 a brick:AHU ;
    rdfs:label "AHU Floor 2" ;
    brick:hasLocation bldg:floor_2 ;
    brick:hasPart bldg:mv_ahu_2 ;
    brick:feeds bldg:vav_f2_z1, bldg:vav_f2_z2, bldg:vav_f2_z3, bldg:vav_f2_z4 ;
    brick:hasPoint bldg:ahu2_room_temp, bldg:ahu2_setpoint, bldg:ahu2_status_read, bldg:ahu2_status_write, bldg:ahu2_humidity, bldg:ahu2_alarm, bldg:ahu2_power .

bldg:mv_ahu_2 a brick:Valve ;
    rdfs:label "Motorized Valve AHU 2" ;
    brick:isPartOf bldg:ahu_2 ;
    brick:hasPoint bldg:mv2_status_read, bldg:mv2_status_write, bldg:mv2_alarm .


# --- AHU & Motorized Valve : Floor 3 -----------------------------------------
bldg:ahu_3 a brick:AHU ;
    rdfs:label "AHU Floor 3" ;
    brick:hasLocation bldg:floor_3 ;
    brick:hasPart bldg:mv_ahu_3 ;
    brick:feeds bldg:vav_f3_z1, bldg:vav_f3_z2, bldg:vav_f3_z3, bldg:vav_f3_z4 ;
    brick:hasPoint bldg:ahu3_room_temp, bldg:ahu3_setpoint, bldg:ahu3_status_read, bldg:ahu3_status_write, bldg:ahu3_humidity, bldg:ahu3_alarm, bldg:ahu3_power .

bldg:mv_ahu_3 a brick:Valve ;
    rdfs:label "Motorized Valve AHU 3" ;
    brick:isPartOf bldg:ahu_3 ;
    brick:hasPoint bldg:mv3_status_read, bldg:mv3_status_write, bldg:mv3_alarm .


# --- AHU & Motorized Valve : Floor 4 -----------------------------------------
bldg:ahu_4 a brick:AHU ;
    rdfs:label "AHU Floor 4" ;
    brick:hasLocation bldg:floor_4 ;
    brick:hasPart bldg:mv_ahu_4 ;
    brick:feeds bldg:vav_f4_z1, bldg:vav_f4_z2, bldg:vav_f4_z3, bldg:vav_f4_z4 ;
    brick:hasPoint bldg:ahu4_room_temp, bldg:ahu4_setpoint, bldg:ahu4_status_read, bldg:ahu4_status_write, bldg:ahu4_humidity, bldg:ahu4_alarm, bldg:ahu4_power .

bldg:mv_ahu_4 a brick:Valve ;
    rdfs:label "Motorized Valve AHU 4" ;
    brick:isPartOf bldg:ahu_4 ;
    brick:hasPoint bldg:mv4_status_read, bldg:mv4_status_write, bldg:mv4_alarm .


# --- VAVs : Floor 1 -----------------------------------------------------------
# แต่ละ VAV ดูแล 1 zone ในชั้นเดียวกัน
bldg:vav_f1_z1 a brick:VAV ;
    rdfs:label "VAV F1-Z1" ;
    brick:hasLocation bldg:floor_1 ;
    brick:feeds bldg:zone_f1_z1 ;
    brick:hasPoint bldg:vav_f1_z1_damper_position, bldg:vav_f1_z1_air_flow_rate, bldg:vav_f1_z1_damper_control .

bldg:vav_f1_z2 a brick:VAV ;
    rdfs:label "VAV F1-Z2" ;
    brick:hasLocation bldg:floor_1 ;
    brick:feeds bldg:zone_f1_z2 ;
    brick:hasPoint bldg:vav_f1_z2_damper_position, bldg:vav_f1_z2_air_flow_rate, bldg:vav_f1_z2_damper_control .

bldg:vav_f1_z3 a brick:VAV ;
    rdfs:label "VAV F1-Z3" ;
    brick:hasLocation bldg:floor_1 ;
    brick:feeds bldg:zone_f1_z3 ;
    brick:hasPoint bldg:vav_f1_z3_damper_position, bldg:vav_f1_z3_air_flow_rate, bldg:vav_f1_z3_damper_control .

bldg:vav_f1_z4 a brick:VAV ;
    rdfs:label "VAV F1-Z4" ;
    brick:hasLocation bldg:floor_1 ;
    brick:feeds bldg:zone_f1_z4 ;
    brick:hasPoint bldg:vav_f1_z4_damper_position, bldg:vav_f1_z4_air_flow_rate, bldg:vav_f1_z4_damper_control .


# --- VAVs : Floor 2 -----------------------------------------------------------
bldg:vav_f2_z1 a brick:VAV ;
    rdfs:label "VAV F2-Z1" ;
    brick:hasLocation bldg:floor_2 ;
    brick:feeds bldg:zone_f2_z1 ;
    brick:hasPoint bldg:vav_f2_z1_damper_position, bldg:vav_f2_z1_air_flow_rate, bldg:vav_f2_z1_damper_control .

bldg:vav_f2_z2 a brick:VAV ;
    rdfs:label "VAV F2-Z2" ;
    brick:hasLocation bldg:floor_2 ;
    brick:feeds bldg:zone_f2_z2 ;
    brick:hasPoint bldg:vav_f2_z2_damper_position, bldg:vav_f2_z2_air_flow_rate, bldg:vav_f2_z2_damper_control .

bldg:vav_f2_z3 a brick:VAV ;
    rdfs:label "VAV F2-Z3" ;
    brick:hasLocation bldg:floor_2 ;
    brick:feeds bldg:zone_f2_z3 ;
    brick:hasPoint bldg:vav_f2_z3_damper_position, bldg:vav_f2_z3_air_flow_rate, bldg:vav_f2_z3_damper_control .

bldg:vav_f2_z4 a brick:VAV ;
    rdfs:label "VAV F2-Z4" ;
    brick:hasLocation bldg:floor_2 ;
    brick:feeds bldg:zone_f2_z4 ;
    brick:hasPoint bldg:vav_f2_z4_damper_position, bldg:vav_f2_z4_air_flow_rate, bldg:vav_f2_z4_damper_control .


# --- VAVs : Floor 3 -----------------------------------------------------------
bldg:vav_f3_z1 a brick:VAV ;
    rdfs:label "VAV F3-Z1" ;
    brick:hasLocation bldg:floor_3 ;
    brick:feeds bldg:zone_f3_z1 ;
    brick:hasPoint bldg:vav_f3_z1_damper_position, bldg:vav_f3_z1_air_flow_rate, bldg:vav_f3_z1_damper_control .

bldg:vav_f3_z2 a brick:VAV ;
    rdfs:label "VAV F3-Z2" ;
    brick:hasLocation bldg:floor_3 ;
    brick:feeds bldg:zone_f3_z2 ;
    brick:hasPoint bldg:vav_f3_z2_damper_position, bldg:vav_f3_z2_air_flow_rate, bldg:vav_f3_z2_damper_control .

bldg:vav_f3_z3 a brick:VAV ;
    rdfs:label "VAV F3-Z3" ;
    brick:hasLocation bldg:floor_3 ;
    brick:feeds bldg:zone_f3_z3 ;
    brick:hasPoint bldg:vav_f3_z3_damper_position, bldg:vav_f3_z3_air_flow_rate, bldg:vav_f3_z3_damper_control .

bldg:vav_f3_z4 a brick:VAV ;
    rdfs:label "VAV F3-Z4" ;
    brick:hasLocation bldg:floor_3 ;
    brick:feeds bldg:zone_f3_z4 ;
    brick:hasPoint bldg:vav_f3_z4_damper_position, bldg:vav_f3_z4_air_flow_rate, bldg:vav_f3_z4_damper_control .


# --- VAVs : Floor 4 -----------------------------------------------------------
bldg:vav_f4_z1 a brick:VAV ;
    rdfs:label "VAV F4-Z1" ;
    brick:hasLocation bldg:floor_4 ;
    brick:feeds bldg:zone_f4_z1 ;
    brick:hasPoint bldg:vav_f4_z1_damper_position, bldg:vav_f4_z1_air_flow_rate, bldg:vav_f4_z1_damper_control .

bldg:vav_f4_z2 a brick:VAV ;
    rdfs:label "VAV F4-Z2" ;
    brick:hasLocation bldg:floor_4 ;
    brick:feeds bldg:zone_f4_z2 ;
    brick:hasPoint bldg:vav_f4_z2_damper_position, bldg:vav_f4_z2_air_flow_rate, bldg:vav_f4_z2_damper_control .

bldg:vav_f4_z3 a brick:VAV ;
    rdfs:label "VAV F4-Z3" ;
    brick:hasLocation bldg:floor_4 ;
    brick:feeds bldg:zone_f4_z3 ;
    brick:hasPoint bldg:vav_f4_z3_damper_position, bldg:vav_f4_z3_air_flow_rate, bldg:vav_f4_z3_damper_control .

bldg:vav_f4_z4 a brick:VAV ;
    rdfs:label "VAV F4-Z4" ;
    brick:hasLocation bldg:floor_4 ;
    brick:feeds bldg:zone_f4_z4 ;
    brick:hasPoint bldg:vav_f4_z4_damper_position, bldg:vav_f4_z4_air_flow_rate, bldg:vav_f4_z4_damper_control .

###############################################################################
# ENVIRONMENTAL MONITORING
###############################################################################


# -----------------------------------------------------------------------------
# SECTION D: ENVIRONMENTAL MONITORING
# IAQ Sensors: 2 ตัวต่อชั้น
# Weather Station: 1 ตัวที่ Roof
# -----------------------------------------------------------------------------

# --- IAQ Sensors : Floor 1 ----------------------------------------------------
bldg:iaq_f1_1 a brick:Air_Quality_Sensor ;
    rdfs:label "IAQ Sensor F1-1" ;
    brick:hasLocation bldg:floor_1 ;
    brick:hasPoint bldg:iaq1_temperature, bldg:iaq1_humidity, bldg:iaq1_co2, bldg:iaq1_pm25 .

bldg:iaq_f1_2 a brick:Air_Quality_Sensor ;
    rdfs:label "IAQ Sensor F1-2" ;
    brick:hasLocation bldg:floor_1 ;
    brick:hasPoint bldg:iaq2_temperature, bldg:iaq2_humidity, bldg:iaq2_co2, bldg:iaq2_pm25 .


# --- IAQ Sensors : Floor 2 ----------------------------------------------------
bldg:iaq_f2_1 a brick:Air_Quality_Sensor ;
    rdfs:label "IAQ Sensor F2-1" ;
    brick:hasLocation bldg:floor_2 ;
    brick:hasPoint bldg:iaq3_temperature, bldg:iaq3_humidity, bldg:iaq3_co2, bldg:iaq3_pm25 .

bldg:iaq_f2_2 a brick:Air_Quality_Sensor ;
    rdfs:label "IAQ Sensor F2-2" ;
    brick:hasLocation bldg:floor_2 ;
    brick:hasPoint bldg:iaq4_temperature, bldg:iaq4_humidity, bldg:iaq4_co2, bldg:iaq4_pm25 .


# --- IAQ Sensors : Floor 3 ----------------------------------------------------
bldg:iaq_f3_1 a brick:Air_Quality_Sensor ;
    rdfs:label "IAQ Sensor F3-1" ;
    brick:hasLocation bldg:floor_3 ;
    brick:hasPoint bldg:iaq5_temperature, bldg:iaq5_humidity, bldg:iaq5_co2, bldg:iaq5_pm25 .

bldg:iaq_f3_2 a brick:Air_Quality_Sensor ;
    rdfs:label "IAQ Sensor F3-2" ;
    brick:hasLocation bldg:floor_3 ;
