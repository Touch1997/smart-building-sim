# ELECTRICAL METERING
###############################################################################


# -----------------------------------------------------------------------------
# SECTION E: ELECTRICAL METERING
# Main meter -> floor submeters + equipment submeters
# ใช้ hasSubMeter / meters เพื่อบอก hierarchy และ meter target
# -----------------------------------------------------------------------------

# --- Main Meter ---------------------------------------------------------------
bldg:main_meter a brick:Building_Meter ;
    rdfs:label "Main Building Meter" ;
    brick:hasLocation bldg:building ;
    brick:hasSubMeter bldg:floor_meter_1, bldg:floor_meter_2, bldg:floor_meter_3, bldg:floor_meter_4, bldg:chiller_meter_1, bldg:chwp_meter_1, bldg:cdwp_meter_1, bldg:ct_meter_1, bldg:chiller_meter_2, bldg:chwp_meter_2, bldg:cdwp_meter_2, bldg:ct_meter_2, bldg:chiller_meter_3, bldg:chwp_meter_3, bldg:cdwp_meter_3, bldg:ct_meter_3, bldg:ahu_meter_1, bldg:ahu_meter_2, bldg:ahu_meter_3, bldg:ahu_meter_4 ;
    brick:hasPoint bldg:main_meter_voltage, bldg:main_meter_current, bldg:main_meter_power, bldg:main_meter_energy, bldg:main_meter_pf .


